{
  "kind": "collectionType",
  "collectionName": "cards",
  "info": {
    "singularName": "card",
    "pluralName": "cards",
    "displayName": "CARD"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": false
    },
    "order": {
      "type": "integer",
      "required": true,
      "unique": false
    },
    "color": {
      "type": "string",
      "default": "FFFFFF",
      "maxLength": 6,
      "required": false
    },
    "column": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::column.column",
      "inversedBy": "cards"
    },
    "deadline": {
      "type": "datetime"
    },
    "labels": {
      "type": "string"
    }
  }
}
